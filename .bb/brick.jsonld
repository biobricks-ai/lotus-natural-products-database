{
  "@context": {
    "@vocab": "https://schema.org/",
    "dcat": "http://www.w3.org/ns/dcat#",
    "dcterms": "http://purl.org/dc/terms/",
    "cheminf": "http://semanticscience.org/resource/",
    "obo": "http://purl.obolibrary.org/obo/"
  },
  "@type": "dcat:Dataset",
  "name": "lotus-natural-products-database",
  "description": "The LOTUS Initiative for Open Natural Products Research: a comprehensive and collaborative natural products database containing over 500,000 unique natural products and their occurrences in organisms.",
  "keywords": ["natural products", "chemistry", "biology", "occurrence", "metabolomics"],
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "dateCreated": "2026-01-29",
  "version": "1.0.0",
  "creator": {
    "@type": "Organization",
    "name": "BioBricks.ai"
  },
  "distribution": [
    {
      "@type": "dcat:Distribution",
      "name": "data.parquet",
      "contentUrl": "brick/data.parquet",
      "encodingFormat": "application/x-parquet"
    }
  ],
  "measurementTechnique": "Computational aggregation",
  "variableMeasured": [
    {
      "@type": "PropertyValue",
      "name": "Chemical Structure"
    },
    {
      "@type": "PropertyValue",
      "name": "Biological Occurrence"
    }
  ]
}
